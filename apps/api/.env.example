# ── Injected automatically by Railway plugins ──────────────────────────────
DATABASE_URL=          # Auto-set by Railway PostgreSQL plugin
REDIS_URL=             # Auto-set by Railway Redis plugin

# ── Required: set these in Railway service variables ───────────────────────
NODE_ENV=production
OPENAI_API_KEY=        # Your OpenAI key (sk-...)

# ── Optional ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=     # Only if using Claude
CORS_ORIGIN=*          # Set to your dashboard URL once deployed, e.g. https://openrooms-dashboard.up.railway.app
LOG_LEVEL=info
PORT=3001              # Railway overrides this automatically
