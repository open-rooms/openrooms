{
  "name": "@openrooms/api",
  "version": "0.2.5",
  "description": "OpenRooms API server - runtime execution and orchestration endpoints",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openrooms/core": "workspace:*",
    "@openrooms/database": "workspace:*",
    "@openrooms/execution": "workspace:*",
    "@openrooms/infrastructure-database": "workspace:*",
    "@openrooms/infrastructure-redis": "workspace:*",
    "@openrooms/infrastructure-queue": "workspace:*",
    "@fastify/cors": "^8.4.2",
    "@fastify/helmet": "^11.1.1",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
